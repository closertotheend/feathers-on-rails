<%- include('../partials/base-begin'); %>
<%- include('../partials/nav'); %>

<section class="hero has-background-light is-fullheight-with-navbar">
  <div class="hero-body">
    <div class="container has-text-centered">
      <div class="column is-4 is-offset-4">
        <h3 class="title has-text-black">New password</h3>
        <div class="box box__login">
          <form action="/confirm-new-password" method="post">
            <%- include('../partials/flash'); %>
            <div class="field">
              <div class="control">
                <input name="password" class="input is-large" type="password" placeholder="Your new password" autofocus="">
              </div>
            </div>
            <div class="field">
              <div class="control">
                <input name="password-confirm" class="input is-large" type="password" placeholder="Confirm new password">
              </div>
            </div>
            <input name="token" type="hidden" value="<%=token %>"/>
            <button class="button is-block is-info is-large is-fullwidth">Set new password</button>
          </form>
        </div>
        <p class="has-text-grey">
          <a href="/signup">Sign Up</a> &nbsp;·&nbsp;
          <a href="/login">Sign in</a>
        </p>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer'); %>
<%- include('../partials/base-end'); %>