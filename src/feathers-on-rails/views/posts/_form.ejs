<form action="/posts<% if(locals.post) { %>/<%= post.id %><% } %>" method="post" class="box">
  <div class="field">
    <label for="heading" class="label">Post heading</label>
    <div class="control">
      <input id="heading" class="input" type="text" placeholder="Heading" name="heading" <% if(locals.post) { %> value="<%- post.heading %>" <% } %>>
    </div>
  </div>
  <div class="field">
    <label for="text" class="label">Post text</label>
    <textarea id="text" class="textarea" placeholder="Content" name="text"><% if(locals.post) {%><%- post.text %><% } %></textarea>
  </div>
  <div class="field is-grouped">
    <div class="control">
      <button type="submit" class="button is-link">Save</button>
    </div>
  </div>
</form>