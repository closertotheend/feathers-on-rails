<% posts.forEach(post => { %>
<section class="section">
  <div class="columns">
    <div class="column is-8 is-offset-2">
      <div class="content is-medium">
        <h2 class="subtitle is-4 is-capitalized"><%= global.dateFns.formatRelative(new Date(post.createdAt), new Date()) %></h2>
        <a href="/posts/<%=post.id %>" class="title"><%= post.heading %> <span class="subtitle">by <%= post.userEmail %></span></a>
        <p><%- post.text %></p>
      </div>
    </div>
  </div>
</section>
<% }) %>

<% if(posts.length > 0) { %>
<div hx-get="/posts/page/<%=nextPageNr %>" hx-trigger="revealed" hx-swap="afterend"></div>
<% } else { %>
<section class="section">
  <div class="columns">
    <div class="column is-8 is-offset-2 has-text-centered">
        All posts loaded. Nothing to load more :(
    </div>
  </div>
</section>
<% } %>